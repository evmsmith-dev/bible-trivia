{
  "name": "bible-trivia",
  "private": true,
  "version": "1.9.2",
  "description": "Bible trivia static app",
  "scripts": {
    "minify:safe": "html-minifier-terser index.html --collapse-whitespace --remove-comments --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --use-short-doctype --minify-css true --minify-js false -o index.min.html",
    "minify:with-js": "html-minifier-terser index.html --collapse-whitespace --remove-comments --remove-redundant-attributes --remove-script-type-attributes --remove-tag-whitespace --use-short-doctype --minify-css true --minify-js true -o index.min.js.html",
    "minify:safe:py": "py scripts/minify_safe.py --source index.source.html --output index.min.html",
    "minify:with-js:py": "py scripts/minify_safe.py --source index.source.html --minify-js --output index.min.js.html",
    "build:pages:py": "py scripts/minify_safe.py --source index.source.html --minify-js --output index.html",
    "build:pages:safe:py": "py scripts/minify_safe.py --source index.source.html --output index.html",
    "test:minified": "node scripts/test-minified.js",
    "test:minified:py": "py scripts/test_minified.py",
    "test:minified-js:py": "py scripts/test_minified.py index.min.js.html",
    "build:minified": "npm run minify:safe && npm run test:minified",
    "build:minified:py": "npm run minify:safe:py && npm run test:minified:py",
    "build:minified-js:py": "npm run minify:with-js:py && npm run test:minified-js:py",
    "verify:pages:py": "py scripts/test_minified.py index.html index.source.html",
    "publish:prep:py": "py scripts/publish_prep.py"
  },
  "devDependencies": {
    "html-minifier-terser": "^7.2.0"
  }
}
